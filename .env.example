# ============================================
# Saham AI — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# Never commit .env files with real secrets.
#
# Quick Setup:
#   1. cp .env.example .env
#   2. Generate JWT secret: openssl rand -hex 32
#   3. Start infrastructure: docker compose up -d
#   4. Run migrations: npx prisma migrate dev
#   5. Seed database: npx prisma db seed
#   6. Fill in your API keys below (optional — mock mode works without them)
# ============================================

# --------------------------------------------
# Application
# --------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Base URL for the app (used in emails, OAuth callbacks)
APP_URL=http://localhost:5173

# --------------------------------------------
# CORS
# --------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173

# --------------------------------------------
# Database (PostgreSQL + Prisma)
# --------------------------------------------
# Setup: docker compose up -d  (starts PostgreSQL on localhost:5432)
#        npx prisma migrate dev
#        npx prisma db seed
DATABASE_URL="postgresql://sahamai:sahamai_dev_pass@localhost:5432/sahamai"

# --------------------------------------------
# Redis (for shared caching across instances)
# --------------------------------------------
# Setup: docker compose up -d  (starts Redis on localhost:6379)
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Authentication
# --------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=YOUR_JWT_SECRET_HERE_MIN_32_CHARS
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# --------------------------------------------
# Stock Data API (optional — mock mode if empty)
# --------------------------------------------
# Get a free API key:
#   Finnhub:    https://finnhub.io/register
#   Alpha Vantage: https://www.alphavantage.co/support/#api-key
#   Polygon:    https://polygon.io/dashboard/api-keys
STOCK_API_KEY=YOUR_STOCK_API_KEY_HERE
STOCK_API_PROVIDER=finnhub

# --------------------------------------------
# AI / LLM (optional — falls back to mock)
# --------------------------------------------
# Get an API key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4

# OpenRouter - Access to multiple models via single API
# Get API key: https://openrouter.ai/keys
# Models: https://openrouter.ai/models
OPENROUTER_API_KEY=sk-or-YOUR_OPENROUTER_API_KEY_HERE
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# OpenCode - Developer-focused AI service
# Get API key: https://opencode.ai/api-keys
OPENCODE_API_KEY=sk-op-YOUR_OPENCODE_API_KEY_HERE
OPENCODE_MODEL=opencode/claude-3.5-sonnet

# Ollama (free local LLM - requires Ollama installation)
# Install: https://ollama.ai/download
# Pull model: ollama pull llama3.2:3b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# LLM Fallback Configuration
# Enable fallback to secondary providers if primary fails
LLM_FALLBACK_ENABLED=true

# Provider priority order (comma-separated, tried in order)
# Available providers: openai, openrouter, opencode, ollama, mock
# mock = always available, provides basic rule-based analysis
LLM_PROVIDER_PRIORITY=openai,openrouter,opencode,ollama,mock

# --------------------------------------------
# TTLs
# --------------------------------------------
SIGNAL_TTL_MS=300000
CACHE_TTL_MS=30000

# --------------------------------------------
# Email / SMTP (for alert notifications and digest)
# --------------------------------------------
# Use any SMTP provider (SendGrid, Mailgun, Resend, etc.)
SMTP_HOST=smtp.provider.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@sahamai.com
# Links in digest emails
APP_URL=http://localhost:5173
# Set false to disable the worker’s digest-email cron (API still supports npm run digest:send)
DIGEST_EMAIL_ENABLED=true

# --------------------------------------------
# Push Notifications (Firebase Cloud Messaging)
# --------------------------------------------
# Setup: https://firebase.google.com/docs/cloud-messaging
# 1. Create a Firebase project
# 2. Go to Project Settings > Cloud Messaging
# 3. Copy the Server Key below
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY_HERE
FCM_PROJECT_ID=YOUR_FCM_PROJECT_ID_HERE

# --------------------------------------------
# SLO Thresholds
# --------------------------------------------
SLO_API_ERROR_RATE_THRESHOLD=0.05
SLO_STALE_RATE_THRESHOLD=0.2
SLO_LATENCY_P95_THRESHOLD_MS=500

# --------------------------------------------
# Alert & Fanout
# --------------------------------------------
ALERT_CHECK_INTERVAL_MS=60000
FANOUT_RETRY_MAX_ATTEMPTS=3
FANOUT_RETRY_BASE_DELAY_MS=1000

# --------------------------------------------
# Telegram Bot (optional — for signal delivery)
# --------------------------------------------
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --------------------------------------------
# Slack (optional — for signal delivery)
# --------------------------------------------
# Create a Slack app and get the webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# --------------------------------------------
# Event Bus (optional — for pub/sub decoupling)
# --------------------------------------------
# Supported: nats, sqs, kafka (leave empty to disable)
EVENT_BUS_PROVIDER=
EVENT_BUS_URL=nats://localhost:4222

# --------------------------------------------
# IHSG Data Provider (optional)
# --------------------------------------------
# For Indonesian market-specific data (IDX)
# Supported: idx_api, goapi, custom
IHSG_DATA_PROVIDER=
IHSG_DATA_API_KEY=
