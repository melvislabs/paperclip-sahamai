// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  googleId      String?   @unique
  avatarUrl     String?
  role          UserRole  @default(USER)
  failedLoginAttempts Int  @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  portfolio     Portfolio?
  alerts        PriceAlert[]
  analyses      AIAnalysis[]
  digestPrefs   DigestPreference?
  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]
  brokerReviews BrokerReview[]
  watchlistItems WatchlistItem[]

  @@index([email])
  @@index([googleId])
}

model Portfolio {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalValue    Decimal   @default(0) @db.Decimal(15, 2)
  cashBalance   Decimal   @default(0) @db.Decimal(15, 2)
  riskScore     Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  holdings      Holding[]

  @@index([userId])
}

model WatchlistItem {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol     String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([userId, symbol])
  @@index([userId, sortOrder])
}

model Holding {
  id            String    @id @default(uuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  symbol        String
  quantity      Int
  avgCostPrice  Decimal   @db.Decimal(10, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([portfolioId, symbol])
  @@index([portfolioId])
}

model Stock {
  id            String    @id @default(uuid())
  symbol        String    @unique
  name          String
  exchange      String?
  sector        String?
  industry      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  prices        StockPrice[]
  analyses      AIAnalysis[]
  alerts        PriceAlert[]

  @@index([symbol])
  @@index([sector])
}

model StockPrice {
  id            String    @id @default(uuid())
  stockId       String
  stock         Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)
  price         Decimal   @db.Decimal(10, 2)
  open          Decimal   @db.Decimal(10, 2)
  high          Decimal   @db.Decimal(10, 2)
  low           Decimal   @db.Decimal(10, 2)
  volume        BigInt
  timestamp     DateTime
  createdAt     DateTime  @default(now())

  @@index([stockId, timestamp])
  @@index([timestamp])
}

model AIAnalysis {
  id            String    @id @default(uuid())
  stockId       String
  stock         Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  analysisType  AnalysisType
  summary       String
  sentiment     Sentiment
  confidence    Float
  riskLevel     RiskLevel
  priceTarget   Decimal?  @db.Decimal(10, 2)
  reasoning     String?
  createdAt     DateTime  @default(now())

  @@index([stockId])
  @@index([userId])
  @@index([analysisType])
  @@index([sentiment])
  @@index([createdAt])
}

model PriceAlert {
  id                    String    @id @default(uuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stockId               String
  stock                 Stock     @relation(fields: [stockId], references: [id], onDelete: Cascade)
  targetPrice           Decimal   @db.Decimal(10, 2)
  condition             AlertCondition
  alertType             AlertType @default(ONE_TIME)
  isActive              Boolean   @default(true)
  triggeredAt           DateTime?
  expiresAt             DateTime?
  cooldownUntil         DateTime?
  notificationChannels  String[]  @default(["in_app"])
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId, isActive])
  @@index([stockId])
  @@index([isActive, expiresAt])
}

model NewsArticle {
  id            String    @id @default(uuid())
  title         String
  url           String    @unique
  source        String
  publishedAt   DateTime
  content       String?
  sentiment     Sentiment @default(NEUTRAL)
  sentimentScore Float    @default(0)
  symbols       String[]
  createdAt     DateTime  @default(now())

  @@index([publishedAt])
  @@index([sentiment])
  @@index([symbols])
}

model DigestPreference {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enabled       Boolean   @default(true)
  deliveryTime  String    @default("08:00")
  timezone      String    @default("UTC")
  includeAlerts Boolean   @default(true)
  includeAnalysis Boolean @default(true)
  includeMarketSummary Boolean @default(true)
  lastDigestSentDate String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])
}

model ApiKey {
  id        String   @id @default(uuid())
  keyHash   String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  role      UserRole @default(USER)
  expiresAt DateTime?
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@index([keyHash])
}

// Broker Information Models
model Broker {
  id                    String    @id @default(uuid())
  name                  String    @unique
  legalName             String
  establishedYear       Int
  ojkLicenseNumber      String    @unique
  ojkLicenseStatus      OjkLicenseStatus
  website               String
  logoUrl               String?
  headquarters          Json
  regulatoryInfo        Json
  contactInfo           Json
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  fees                  BrokerFees?
  features              BrokerFeatures?
  reviews               BrokerReview[]
  performanceMetrics    BrokerPerformance[]

  @@index([name])
  @@index([ojkLicenseStatus])
}

model BrokerFees {
  id            String    @id @default(uuid())
  brokerId      String    @unique
  broker        Broker    @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  tradingFees   Json
  accountFees   Json
  otherFees     Json
  promotions    Json      @default("[]")
  effectiveDate  DateTime
  updatedAt     DateTime  @updatedAt

  @@index([brokerId])
}

model BrokerFeatures {
  id              String    @id @default(uuid())
  brokerId        String    @unique
  broker          Broker    @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  tradingPlatforms Json
  researchTools   Json
  orderTypes      Json
  accountTypes    Json
  apiAccess       Json
  education       Json
  lastUpdated     DateTime  @default(now())

  @@index([brokerId])
}

model BrokerReview {
  id                    String    @id @default(uuid())
  brokerId              String
  broker                Broker    @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAccountType       String
  tradingExperience     String
  tradingFrequency      String
  overallRating         Int       @default(0)
  criteriaRatings       Json
  pros                  String[]  @default([])
  cons                  String[]  @default([])
  detailedReview        String?
  wouldRecommend        Boolean   @default(false)
  verifiedAccount       Boolean   @default(false)
  helpfulVotes          Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([brokerId])
  @@index([userId])
  @@index([overallRating])
}

model BrokerPerformance {
  id                      String    @id @default(uuid())
  brokerId                String
  broker                  Broker    @relation(fields: [brokerId], references: [id], onDelete: Cascade)
  date                    DateTime
  systemMetrics           Json
  tradingMetrics          Json
  customerServiceMetrics  Json
  lastUpdated             DateTime  @default(now())

  @@index([brokerId])
  @@index([date])
}

enum UserRole {
  ADMIN
  USER
  SERVICE
}

enum AnalysisType {
  TECHNICAL
  FUNDAMENTAL
  SENTIMENT
  PORTFOLIO_RISK
  DAILY_DIGEST
}

enum Sentiment {
  BULLISH
  BEARISH
  NEUTRAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertCondition {
  ABOVE
  BELOW
  PERCENT_CHANGE
}

enum AlertType {
  ONE_TIME
  RECURRING
  EXPIRING
}

enum OjkLicenseStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}
