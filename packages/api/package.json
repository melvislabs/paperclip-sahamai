{
  "name": "@sahamai/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./digest-batch": {
      "types": "./dist/jobs/digest-batch.d.ts",
      "import": "./dist/jobs/digest-batch.js",
      "default": "./dist/jobs/digest-batch.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "default": "./dist/db/index.js"
    },
    "./alerts/monitor": {
      "types": "./dist/services/alerts/monitor.d.ts",
      "import": "./dist/services/alerts/monitor.js",
      "default": "./dist/services/alerts/monitor.js"
    },
    "./alerts/notifier": {
      "types": "./dist/services/alerts/notifier.d.ts",
      "import": "./dist/services/alerts/notifier.js",
      "default": "./dist/services/alerts/notifier.js"
    },
    "./alerts/types": {
      "types": "./dist/services/alerts/types.d.ts",
      "import": "./dist/services/alerts/types.js",
      "default": "./dist/services/alerts/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "smoke:runtime": "node scripts/smoke-runtime.mjs",
    "smoke:deploy": "node scripts/smoke-deploy.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "digest:send": "tsx src/jobs/digest-batch-cli.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@fastify/websocket": "^11.2.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@sahamai/shared": "0.1.0",
    "@sinclair/typebox": "^0.34.49",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.6.1",
    "fastify": "^5.1.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@prisma/client": "^7.6.0",
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^6.4.0",
    "prisma": "^7.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
